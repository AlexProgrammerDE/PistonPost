{
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "scripts/**/*.ts",
    "tests/**/*.ts",
    "*.config.ts",
    "worker-configuration.d.ts"
  ],
  "exclude": [
    "tools/**",
    "src/components/auth/api-key/**",
    "src/components/auth/email/**",
    "src/components/auth/multi-session/**",
    "src/components/auth/organization/**",
    "src/components/auth/username/**",
    "src/components/auth/settings/account/user-profile.tsx",
    "src/components/auth/settings/settings.tsx",
    "src/components/auth/user/user-button.tsx",
    "src/components/auth/user/user-view.tsx",
    "src/lib/auth/api-key-plugin.ts",
    "src/lib/auth/multi-session-plugin.ts",
    "src/lib/auth/organization-plugin.tsx"
  ],
  "compilerOptions": {
    "target": "ES2022",
    "jsx": "react-jsx",
    "module": "ESNext",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "types": ["bun", "vite/client"],
    "paths": {
      "@/*": ["./src/*"]
    },
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  }
}

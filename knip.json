{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignoreExportsUsedInFile": true,
  "entry": [
    "auth-schema.config.ts",
    "drizzle.config.ts",
    "playwright.config.ts",
    "vite.config.ts",
    "scripts/**/*.ts",
    "tests/e2e/**/*.ts",
    "src/lib/auth/auth-plugin.ts",
    "src/router.tsx",
    "src/routes/**/*.{ts,tsx}",
    "src/styles/**/*.css",
    "tools/migrate/src/index.ts",
    "tools/migrate/src/**/*.test.ts"
  ],
  "project": [
    "*.ts",
    "scripts/**/*.ts",
    "tests/**/*.ts",
    "src/**/*.{ts,tsx}",
    "tools/migrate/src/**/*.ts"
  ],
  "ignore": [
    "src/routeTree.gen.ts",
    "src/components/auth/**",
    "src/components/ui/**",
    "src/lib/auth/api-key-plugin.ts",
    "src/lib/auth/multi-session-plugin.ts",
    "src/lib/auth/organization-plugin.tsx"
  ],
  "ignoreDependencies": [
    "@tailwindcss/vite",
    "@tanstack/react-devtools",
    "@tanstack/react-router-devtools",
    "@tanstack/router-plugin",
    "@tanstack/react-pacer",
    "cloudflare",
    "drizzle-kit",
    "embla-carousel-react",
    "oxfmt",
    "oxlint",
    "oxlint-tsgolint",
    "shadcn",
    "tailwindcss",
    "tw-animate-css",
    "zod"
  ]
}

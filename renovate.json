{
  "extends": ["config:recommended", "group:allNonMajor", ":semanticCommits"],
  "reviewers": ["AlexProgrammerDE"],
  "packageRules": [
    {
      "description": "Keep dash.js aligned with the Vidstack DASH provider",
      "matchPackageNames": ["dashjs"],
      "allowedVersions": "4.7.4"
    },
    {
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "automerge": true,
      "automergeType": "branch"
    }
  ]
}

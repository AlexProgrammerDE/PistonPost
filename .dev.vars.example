# Copy this file to .dev.vars for local authentication development.
# Keep real values out of version control.
# Generate a value with `openssl rand -base64 48`.
BETTER_AUTH_SECRET=
# Signs category-scoped email unsubscribe links. Use a separate random value.
EMAIL_UNSUBSCRIBE_SECRET=
# Required in product update emails. Use the monitored business postal address.
MARKETING_POSTAL_ADDRESS=
# Better Auth dashboard API key used by Dash and Sentinel.
BETTER_AUTH_API_KEY=
# Use Cloudflare's always-pass test secret for local development only.
TURNSTILE_SECRET=1x0000000000000000000000000000000AA
# Returned when the local tunnel webhook URL is registered with Stream.
STREAM_WEBHOOK_SECRET=
# Cloudflare account that owns the Stream binding. Required for resumable TUS uploads.
STREAM_ACCOUNT_ID=
# Dedicated API token with Stream Write permission. Do not reuse a deployment token.
STREAM_API_TOKEN=
# Generate this key pair once with `bunx web-push generate-vapid-keys`.
# Put the public half in VAPID_PUBLIC_KEY in wrangler.jsonc.
VAPID_PRIVATE_KEY=

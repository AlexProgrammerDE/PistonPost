    "@tanstack/react-table": "9.0.0-beta.19",
    "@vidstack/react": "1.15.6",
    "better-auth": "1.6.23",
    "better-auth-harmony": "1.3.2",
    "bowser": "2.14.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "dashjs": "5.2.0",
    "date-fns": "4.4.0",
    "drizzle-orm": "0.45.2",
    "effect": "3.22.0",
    "embla-carousel-react": "^8.6.0",
    "fscreen": "1.2.0",
    "lucide-react": "1.24.0",
    "motion": "12.42.2",
    "next-themes": "0.4.6",
    "posthog-js": "^1.402.3",
    "react": "19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.7",
    "react-markdown": "^10.1.0",

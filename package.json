{
  "name": "@pistonpost/root",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@pistonpost/web",
    "bundle:check": "bun scripts/check-client-bundles.ts",
    "cf:typegen": "bun run --cwd apps/web cf:typegen",
    "check": "bun run format:check && bun run lint && bun run typecheck && bun run test",
    "ci": "bun run check && bun run knip && bun run build && bun run bundle:check && bun run wrangler:dry-run",
    "dev": "turbo run dev --parallel",
    "dev:web": "turbo run dev --filter=@pistonpost/web",
    "db:check": "bun run --cwd packages/db db:check",
    "db:generate": "bun run --cwd packages/db db:generate",
    "fix": "oxfmt . && oxlint --type-aware --fix --fix-suggestions .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "generated:check": "bun scripts/check-generated.ts",
    "knip": "knip",
    "lint": "oxlint --type-aware --deny-warnings --report-unused-disable-directives .",
    "load:test": "bun scripts/load-test.ts",
    "migrate": "bun apps/migrate/src/index.ts",
    "migrate:legacy": "bun apps/migrate/src/index.ts",
    "prepare": "./scripts/prepare-effect.sh && lefthook install",
    "smoke:production": "bun scripts/smoke-production.ts",
    "test": "turbo run test",
    "test:e2e": "playwright test",
    "test:web": "turbo run test --filter=@pistonpost/web",
    "typecheck": "turbo run typecheck",
    "typecheck:web": "turbo run typecheck --filter=@pistonpost/web",
    "wrangler:dry-run": "bun run --cwd apps/web deploy:dry-run"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@happy-dom/global-registrator": "20.10.6",
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/bun": "1.3.14",
    "@typescript/native-preview": "7.0.0-dev.20260707.2",
    "happy-dom": "20.10.6",
    "knip": "6.26.0",
    "lefthook": "2.1.10",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "oxlint-tsgolint": "0.24.0",
    "turbo": "2.10.5",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "bun@1.3.13",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}

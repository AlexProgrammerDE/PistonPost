{
  "name": "pistonpost",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "bundle:check": "bun scripts/check-client-bundles.ts",
    "cf:typegen": "wrangler types --env-interface Env --env-file .dev.vars.example",
    "check": "bun run format:check && bun run lint && bun run typecheck && bun run test",
    "ci": "bun run check && bun run knip && bun run build && bun run bundle:check && bun run wrangler:dry-run",
    "deploy:prepare:production": "bun scripts/prepare-production-deploy.ts",
    "deploy:dry-run": "bun run build && wrangler deploy --dry-run",
    "dev": "node node_modules/vite/bin/vite.js dev --port 3000",
    "dev:web": "bun run dev",
    "db:check": "drizzle-kit check",
    "db:generate": "drizzle-kit generate",
    "fix": "oxfmt . && oxlint --type-aware --fix --fix-suggestions .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "generated:check": "bun scripts/check-generated.ts",
    "knip": "knip",
    "lint": "oxlint --type-aware --deny-warnings --report-unused-disable-directives .",
    "load:test": "bun scripts/load-test.ts",
    "prepare": "./scripts/prepare-effect.sh && lefthook install",
    "preview": "vite preview",
    "smoke:production": "bun scripts/smoke-production.ts",
    "test": "bun test --path-ignore-patterns='tests/e2e/**'",
    "test:e2e": "playwright test",
    "test:web": "bun test --path-ignore-patterns='tests/e2e/**'",
    "typecheck": "tsgo --noEmit",
    "typecheck:web": "tsgo --noEmit",
    "wrangler:dry-run": "bun run deploy:dry-run"
  },
  "dependencies": {
    "@base-ui/react": "1.6.0",
    "@better-auth-ui/core": "^1.6.27",
    "@better-auth-ui/react": "^1.6.27",
    "@better-auth/api-key": "1.6.23",
    "@better-auth/drizzle-adapter": "1.6.23",
    "@better-auth/infra": "^0.3.2",
    "@better-auth/passkey": "1.6.23",
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@fontsource-variable/outfit": "5.2.8",
    "@marsidev/react-turnstile": "1.5.3",
    "@react-email/components": "1.0.12",
    "@react-email/render": "2.0.4",
    "@tanstack/react-form": "1.33.2",
    "@tanstack/react-pacer": "0.22.1",
    "@tanstack/react-query": "5.101.2",
    "@tanstack/react-router": "1.170.18",
